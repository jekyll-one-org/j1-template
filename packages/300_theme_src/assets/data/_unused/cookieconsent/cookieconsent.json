---
regenerate:                             true
exclude_from_search:                    true
---

{%- capture cache -%}

{% comment %}
 # -----------------------------------------------------------------------------
 # ~/assets/data/cookieconsent.json (0)
 # Liquid PROCEDURE to generate the data payload used by the
 # J1 Cookie Consent module
 #
 # Product/Info:
 # https://jekyll.one
 #
 # Copyright (C) 2026 Juergen Adams
 #
 # J1 Template is licensed under the MIT License.
 # See: https://github.com/jekyll-one-org/j1-template/blob/main/LICENSE
 # -----------------------------------------------------------------------------
 # claude - improve cookieConsent code using lit #1
 # ---------------------------------------------------------------------------
 # Refactored to emit a JSON configuration payload instead of HTML
 # markup. The Lit-based <j1-cookie-consent> component renders the
 # modal declaratively from this configuration, so the HTML structure
 # is no longer transmitted from server to client. Only the localized
 # text strings (plus a few labels) flow through this endpoint.
 #
 # Original responsibility (still preserved):
 #   - Read site/module config via Jekyll/Liquid
 #   - Deliver localized text content to the client
 #
 # Removed responsibility:
 #   - Shipping Bootstrap modal markup (now baked into the component)
 #   - Carrying element IDs that the JS needs to query for
 #   - Going through the compress_html / strip_html_comments pipeline
 #     (not applicable to a JSON payload, and was a source of the bug
 #     where `.modal-dialog` got stripped under aggressive minification)
 # ---------------------------------------------------------------------------
{% endcomment %}

{% comment %} Set global settings
-------------------------------------------------------------------------------- {% endcomment %}
{% assign environment      = site.environment %}

{% comment %} Set config files
-------------------------------------------------------------------------------- {% endcomment %}
{% assign modules          = site.data.modules %}
{% assign consent_defaults = modules.defaults.cookieconsent.defaults %}
{% assign consent_settings = modules.cookieconsent.settings %}

{% comment %} Set config options
-------------------------------------------------------------------------------- {% endcomment %}
{% assign consent_options  = consent_defaults | merge: consent_settings %}

{% comment %} Optional override block: a module may publish localized
   button/section labels under `modules.cookieconsent.labels` to fully
   internationalize the modal. If absent, English defaults are used.
-------------------------------------------------------------------------------- {% endcomment %}
{% assign consent_labels   = modules.cookieconsent.labels %}

{
  "title":         {{ consent_options.modal_settings.title          | jsonify }},
  "bodyText":      {{ consent_options.modal_settings.body_text      | jsonify }},
  "privacyNotice": {{ consent_options.modal_settings.privacy_notice | jsonify }},
  "labels": {
    "privacyNotice":       {{ consent_labels.privacyNotice       | default: "Privacy Notice"  | jsonify }},
    "mySettings":          {{ consent_labels.mySettings          | default: "My Settings"     | jsonify }},

    "necessary":           {{ consent_labels.necessary           | default: "Necessary"       | jsonify }},
    "necessaryDesc":       {{ consent_labels.necessaryDesc       | default: "Required to run the website" | split: "|" | jsonify }},

    "analysis":            {{ consent_labels.analysis            | default: "Analysis"        | jsonify }},
    "analysisDesc":        {{ consent_labels.analysisDesc        | default: "Usage monitoring for this site|Optimizing of the performance for this site|Optimizing of content for all visitors" | split: "|" | jsonify }},

    "personalization":     {{ consent_labels.personalization     | default: "Personalization" | jsonify }},
    "personalizationDesc": {{ consent_labels.personalizationDesc | default: "Enable Translation services|Enable Advertising services|Storage of personal preferences from previous visits|Enable Comment services to exchange visitor's experiences" | split: "|" | jsonify }},

    "buttonDoNotAgree":    {{ consent_labels.buttonDoNotAgree    | default: "I Do not Agree"  | jsonify }},
    "buttonDoNothing":     {{ consent_labels.buttonDoNothing     | default: "Do Nothing"      | jsonify }},
    "buttonAgree":         {{ consent_labels.buttonAgree         | default: "I Agree"         | jsonify }},
    "buttonSave":          {{ consent_labels.buttonSave          | default: "Save selection"  | jsonify }},
    "buttonAgreeAll":      {{ consent_labels.buttonAgreeAll      | default: "Agree on all"    | jsonify }},
    "close":               {{ consent_labels.close               | default: "Close"           | jsonify }}
  }
}
{%- endcapture -%}

{% comment %} claude - improve cookieConsent code using lit #1
 # Emit the JSON payload as-is. The previous compress_html /
 # strip_html_comments pipeline does not apply to JSON output and
 # could (under aggressive `endings: all` settings) corrupt the
 # response. A single `strip` keeps things tidy without risk.
-------------------------------------------------------------------------------- {% endcomment %}
{{ cache | strip }}

{% comment %} Reset page cache
-------------------------------------------------------------------------------- {% endcomment %}
{%- assign cache = false -%}

